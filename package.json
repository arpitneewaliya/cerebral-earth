{
  "name": "cerebral-earth-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "news-app",
    "news-api"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:frontend": "npm run dev --workspace=news-app",
    "dev:backend": "npm run dev --workspace=news-api",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react-icons": "^5.6.0",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
